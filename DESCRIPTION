Package: cgvR
Type: Package
Title: Interactive 3D Visualization of Large Cayley Graphs via Vulkan
Version: 0.1.2
Authors@R: c(
    person("Yuri", "Baramykov",
        email = "lbsbmsu@mail.ru",
