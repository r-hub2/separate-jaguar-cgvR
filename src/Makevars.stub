# Generated by configure — stub build (no Vulkan / GLFW available).
# Compiles only cgv_stub.c, which provides .Call entries that raise
# an informative R error when invoked. Pure-R helpers (cgv_layout_fr,
# cgv_layout_fr_bh wrappers, …) still work — well, cgv_layout_fr_bh hits
# the stub since it goes through .Call, but cgv_layout_fr is pure R.

OBJECTS = cgv_stub.o
